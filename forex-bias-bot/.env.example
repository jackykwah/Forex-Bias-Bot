# Groq API (free tier) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI (free: 100 req/day) - https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage (backup, free: 25 req/day) - https://www.alphavantage.co
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Discord Webhook URL (from Discord channel settings)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Trading pairs to monitor (comma-separated)
TRADING_PAIRS=USD/JPY,GBP/JPY,GBP/USD
